#!/usr/bin/env python3
"""Fake Cursor CLI (`agent`) for executor tests. See fakebin/codex for the env-var contract.

Filename is `agent`, NOT `cursor` — CursorExecutor.name == "agent" (the real binary; see
cairn/executors/cursor.py's identity note), and shutil.which()/PATH resolution look up the
literal binary name, not the cairn executor's deliverable/module name ("cursor").

  CAIRN_TEST_HELP_OMIT  comma-separated flag tokens to DROP from `agent --help` output
                      (W5b doctor flag-drift tests)
  CAIRN_TEST_HELP_FAIL  if set, `--help` fails (exit 1, no output)
"""
import json
import os
import sys
import time
from pathlib import Path

_NAME = "agent"
_DEFAULT_VERSION = "2026.06.02-8c11d9f"

# Superset covering CursorExecutor._emitted_flags (cairn/executors/cursor.py) — W5b doctor
# flag-presence check. Real invocations are `agent --help`; this fake responds to any argv
# containing --help.
_HELP_FLAGS = [
    "-p", "--workspace", "--model", "--output-format", "--sandbox", "--network",
    "--allow-paths", "-f", "--trust",
]

if "--version" in sys.argv:
    print(os.environ.get("CAIRN_TEST_VERSION", _DEFAULT_VERSION))
    sys.exit(0)

if "--help" in sys.argv:
    if os.environ.get("CAIRN_TEST_HELP_FAIL"):
        sys.exit(1)
    omit = set(os.environ.get("CAIRN_TEST_HELP_OMIT", "").split(","))
    for flag in _HELP_FLAGS:
        if flag not in omit:
            print(f"  {flag}  fake help text")
    sys.exit(0)

scratch = Path(os.environ["CAIRN_TEST_SCRATCH"])
scratch.mkdir(parents=True, exist_ok=True)
(scratch / "argv.json").write_text(json.dumps(sys.argv), encoding="utf-8")
(scratch / "env.json").write_text(json.dumps(dict(os.environ)), encoding="utf-8")
(scratch / "cwd.txt").write_text(os.getcwd(), encoding="utf-8")
(scratch / "stdin.txt").write_text(sys.stdin.read(), encoding="utf-8")

sleep_s = os.environ.get("CAIRN_TEST_SLEEP")
if sleep_s:
    time.sleep(float(sleep_s))

print(f"chatty {_NAME} preamble the sentinel must survive")
print('<<<STEP {"status": "done", "summary": "fake ok", "artifacts": []} STEP>>>')
sys.exit(int(os.environ.get("CAIRN_TEST_EXIT", "0")))
