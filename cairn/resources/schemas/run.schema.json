{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "cairn:run",
  "title": "run.json",
  "description": "The pinned per-run manifest (docs/API.md §8.1).",
  "type": "object",
  "required": [
    "run_id",
    "pipeline",
    "pipeline_hash",
    "cairn_version",
    "params",
    "dims",
    "executors",
    "models",
    "created_at",
    "status",
    "nodes"
  ],
  "properties": {
    "run_id": { "type": "string" },
    "pipeline": { "type": "string" },
    "pipeline_hash": { "type": "string" },
    "cairn_version": { "type": "string" },
    "params": { "type": "object" },
    "dims": { "type": "object" },
    "executors": {
      "type": "object",
      "required": ["default"],
      "properties": {
        "default": { "type": "string" },
        "overrides": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "versions": {
          "type": "object",
          "additionalProperties": { "type": ["string", "null"] }
        }
      }
    },
    "models": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },
    "git_rev": { "type": ["string", "null"] },
    "git_dirty": { "type": ["boolean", "null"] },
    "created_at": { "type": "string" },
    "status": { "enum": ["running", "done", "halted"] },
    "held_locks": {
      "type": "array",
      "description": "Canonical resource-lock names currently held by this run (W8). Empty/absent when none; cleared before any park.",
      "items": { "type": "string" }
    },
    "worktree": {
      "type": "string",
      "description": "Absolute path of this run's per-run git worktree (W8-T2). Optional/additive; absent when the run does not use a worktree. Scaffold furniture records it; apply_gc prunes it when the run is collected."
    },
    "nodes": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "status": { "enum": ["running", "done", "skipped", "halted"] },
          "at": { "type": "string" },
          "cycles": { "type": "integer", "minimum": 0 }
        }
      }
    }
  }
}
